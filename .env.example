# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App
NEXT_PUBLIC_APP_NAME=Funnely
NEXT_PUBLIC_URL=http://localhost:3000

# 로컬 개발 서버가 3000번이 아닌 다른 포트로 뜰 경우(예: 3000번이 이미 사용 중)
# 랜딩페이지 공개 링크가 여전히 localhost:3000을 가리키지 않도록 실제 포트로 맞춰준다.
# 미설정 시 'localhost:3000'으로 폴백됨 (src/lib/utils/landing-page-url.ts)
# NEXT_PUBLIC_DEV_DOMAIN=localhost:3001

# Resend Email Service
RESEND_API_KEY=your_resend_api_key

# Cron Job Security
CRON_SECRET=your_secure_random_string

# Toss Payments
NEXT_PUBLIC_TOSS_CLIENT_KEY=your_toss_client_key
TOSS_SECRET_KEY=your_toss_secret_key

# NOTE: Ad platform API credentials (Meta, Kakao, Google) are now managed
# through the UI at /dashboard/settings/api-credentials
# Each company can configure their own credentials in the database

# Encryption keys (AES, used by src/lib/encryption/*)
PHONE_ENCRYPTION_KEY=your_base64_secret_key
# API_CREDENTIALS_ENCRYPTION_KEY: optional, separate key for ad-platform API
# credentials (Meta/Kakao/Google secrets). Falls back to PHONE_ENCRYPTION_KEY if unset.
API_CREDENTIALS_ENCRYPTION_KEY=your_base64_secret_key
